# Bytecode and interpreter caches
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Python build and packaging outputs
*.egg-info/
*.egg
.eggs/
build/
dist/
wheelhouse/

# Test, type-check, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local Jarvis-Agent configuration
.jarvis-agent.toml

# Local model artifacts, adapters, and generated datasets
adapters/
data/hep_lora/
models/
checkpoints/
runs/
outputs/

# Hugging Face and MLX caches if configured inside the repo
.cache/
hf_cache/
huggingface/
mlx_cache/

# Logs and local runtime state
*.log
logs/
tmp/
temp/

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo
